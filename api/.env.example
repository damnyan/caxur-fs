PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/caxur
RUST_LOG=caxur=debug,tower_http=debug

# Database Pool Configuration
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5
DB_ACQUIRE_TIMEOUT_SECS=3
DB_IDLE_TIMEOUT_SECS=600

# JWT Configuration
JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n..."
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Rate Limiting
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=60
RATE_LIMIT_PER_MINUTE=300

# Service URLs
ADMIN_URL=http://localhost:3001
CLIENT_URL=http://localhost:3002

# SMTP Configuration (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=mailpit
SMTP_PASSWORD=mailpit
SMTP_FROM=noreply@caxur.com
APP_NAME=Caxur

# Documentation / OpenAPI Configuration
SWAGGER_ENABLED=false

# AWS / S3 Storage Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=caxur-uploads
AWS_S3_ENDPOINT=http://localhost:9000
